{
  "manifest_version": 3,
  "name": "ChatGPT Gateway",
  "version": "1.0.0",
  "description": "Local API gateway for ChatGPT — automates your logged-in session",
  "browser_specific_settings": {
    "gecko": {
      "id": "chatgpt-gateway@draivix.com",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["activeTab", "scripting", "alarms"],
  "host_permissions": ["https://chatgpt.com/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ChatGPT Gateway"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
